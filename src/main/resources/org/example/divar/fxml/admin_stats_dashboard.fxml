<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.divar.controller.AdminMainDashboardController"
      spacing="20.0" style="-fx-padding: 30px; -fx-background-color: #f9f9f9;"
      prefWidth="1000.0" prefHeight="700.0">

    <children>
        <Label text="داشبورد آماری سیستم" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>

        <GridPane hgap="20.0" vgap="20.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0"/>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0"/>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="120.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="120.0" vgrow="SOMETIMES"/>
            </rowConstraints>
            <children>

                <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <children>
                        <Label text="کاربران فعال" style="-fx-font-size: 14px; -fx-text-fill: #666666;"/>
                        <Label fx:id="lblActiveUsers" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2e7d32; -fx-padding: 10px 0 0 0;"/>
                    </children>
                </VBox>

                <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <children>
                        <Label text="کاربران مسدود" style="-fx-font-size: 14px; -fx-text-fill: #666666;"/>
                        <Label fx:id="lblBlockedUsers" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #c62828; -fx-padding: 10px 0 0 0;"/>
                    </children>
                </VBox>

                <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <children>
                        <Label text="کل آگهی‌ها" style="-fx-font-size: 14px; -fx-text-fill: #666666;"/>
                        <Label fx:id="lblTotalAds" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1565c0; -fx-padding: 10px 0 0 0;"/>
                    </children>
                </VBox>

                <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <children>
                        <Label text="آگهی‌های در انتظار بررسی" style="-fx-font-size: 14px; -fx-text-fill: #666666;"/>
                        <Label fx:id="lblPendingAds" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #ef6c00; -fx-padding: 10px 0 0 0;"/>
                    </children>
                </VBox>

                <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <children>
                        <Label text="گزارش‌های تخلف" style="-fx-font-size: 14px; -fx-text-fill: #666666;"/>
                        <Label fx:id="lblReports" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #6a1b9a; -fx-padding: 10px 0 0 0;"/>
                    </children>
                </VBox>
            </children>
        </GridPane>
    </children>
</VBox>
