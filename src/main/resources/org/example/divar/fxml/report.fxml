<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="400.0" spacing="0.0" styleClass="dialog-root"
      nodeOrientation="RIGHT_TO_LEFT" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.divar.controller.ReportDialogController">
    <children>

        <HBox alignment="CENTER_LEFT" styleClass="dialog-header">
            <children>
                <Label text="گزارش آگهی" styleClass="dialog-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="✕" onAction="#closeReportWindow" styleClass="dialog-close-btn" />
            </children>
        </HBox>

        <VBox spacing="14.0" styleClass="dialog-content">
            <children>
                <fx:define>
                    <ToggleGroup fx:id="reportGroup" />
                </fx:define>
                <RadioButton fx:id="reasonFraud" text="کلاهبرداری" toggleGroup="$reportGroup" selected="true" styleClass="dialog-radio" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                <RadioButton fx:id="reasonImmoral" text="غیرقانونی یا غیراخلاقی" toggleGroup="$reportGroup" styleClass="dialog-radio" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                <RadioButton fx:id="reasonWrongCategory" text="دسته‌بندی اشتباه" toggleGroup="$reportGroup" styleClass="dialog-radio" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                <RadioButton fx:id="reasonWrongPrice" text="قیمت اشتباه" toggleGroup="$reportGroup" styleClass="dialog-radio" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                <RadioButton fx:id="reasonWrongInfo" text="اطلاعات اشتباه" toggleGroup="$reportGroup" styleClass="dialog-radio" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                <RadioButton fx:id="reasonDuplicate" text="تکراری یا اسپم" toggleGroup="$reportGroup" styleClass="dialog-radio" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                <RadioButton fx:id="reasonUnavailable" text="ناموجود یا پاسخگو نبودن" toggleGroup="$reportGroup" styleClass="dialog-radio" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                <RadioButton fx:id="reasonOthers" text="سایر" toggleGroup="$reportGroup" styleClass="dialog-radio" maxWidth="Infinity" alignment="CENTER_LEFT"/>

                <Label fx:id="messageLabel" visible="false" managed="false" style="-fx-text-fill: #a62626; -fx-font-size: 13px; -fx-font-weight: bold;" wrapText="true"/>
            </children>
        </VBox>

        <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="dialog-footer">
            <children>
                <Button text="تأیید و ادامه" onAction="#sendReport" styleClass="dialog-submit-btn" />
                <Button text="بازگشت" onAction="#closeReportWindow" styleClass="dialog-cancel-btn" />
            </children>
        </HBox>

    </children>
</VBox>


