<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.divar.controller.ProfileController"
            prefWidth="1100.0" prefHeight="700.0"
            style="-fx-background-color: #f9f9f9;"
            nodeOrientation="RIGHT_TO_LEFT">

    <top>
        <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-background-color: #ffffff;" prefHeight="65.0">
            <padding>
                <Insets top="10.0" bottom="10.0" left="20.0" right="20.0"/>
            </padding>
            <children>
                <VBox alignment="CENTER_RIGHT" spacing="2.0">
                    <children>
                        <Label text="ШҜЫҢЩҲШ§Шұ Щ…ЩҶ" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #a62626;"/>
                        <Label text="ШӯШіШ§ШЁ Ъ©Ш§ШұШЁШұЫҢ Ъ©Ш§ШұШЁШұ" style="-fx-font-size: 11px; -fx-text-fill: #999999;"/>
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button text="ЪҶШӘ" onAction="#goToChat"
                        style="-fx-background-color: white; -fx-text-fill: #222222; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-padding: 6px 14px; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                <Button fx:id="backBtn" text="ШЁШ§ШІЪҜШҙШӘ" onAction="#goBack"
                        style="-fx-background-color: white; -fx-text-fill: #222222; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-padding: 6px 14px; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </children>
        </HBox>
    </top>

    <left>
        <HBox prefWidth="180.0" styleClass="profile-sidebar">
            <children>
                <VBox fx:id="indicatorContainer" prefWidth="4.0" style="-fx-padding: 30px 0 30px 0;">
                    <children>
                        <Region fx:id="activeIndicator" prefHeight="26.0" prefWidth="4.0" style="-fx-background-color: #a62626;" visible="false"/>
                    </children>
                </VBox>

                <VBox spacing="18.0" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" style="-fx-padding: 30px 15px 30px 10px;">
                    <children>
                        <Hyperlink fx:id="favoriteLink" text="ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢ ЩҶШҙШ§ЩҶвҖҢШҙШҜЩҮ" onAction="#showFavorites"
                                   styleClass="menu-link-normal"/>

                        <Hyperlink fx:id="advertisementLink" text="ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢ Щ…ЩҶ" onAction="#showMyAdvertisements"
                                   styleClass="menu-link-normal"/>

                        <Region VBox.vgrow="ALWAYS" />

                        <Button text="Ш®ШұЩҲШ¬ Ш§ШІ ШӯШіШ§ШЁ" onAction="#logout" alignment="CENTER_LEFT"
                                style="-fx-background-color: transparent; -fx-text-fill: #a62626; -fx-font-size: 14px; -fx-padding: 5px 0; -fx-cursor: hand; -fx-font-weight: bold;"/>
                    </children>
                </VBox>
            </children>
        </HBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;">
            <content>
                <StackPane style="-fx-background-color: #f9f9f9; -fx-padding: 40px;" alignment="CENTER">
                    <children>
                        <VBox fx:id="menu" spacing="15.0" style="-fx-background-color: transparent;" alignment="TOP_RIGHT" />
                        <Label fx:id="emptyLabel" text="Щ„Ш·ЩҒШ§ЩӢ ЫҢЪ©ЫҢ Ш§ШІ ЪҜШІЫҢЩҶЩҮвҖҢЩҮШ§ЫҢ Щ…ЩҶЩҲ ШұШ§ Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ."
                               style="-fx-font-size: 15px; -fx-text-fill: #888888; -fx-font-weight: bold;"
                               StackPane.alignment="CENTER" />
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>








