<?xml version="1.0" encoding="UTF-8"?>



<?import javafx.geometry.Insets?>

<?import javafx.scene.control.*?>

<?import javafx.scene.layout.*?>

<?import org.kordamp.ikonli.javafx.FontIcon?>



<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"

            fx:controller="org.example.divar.controller.ProfileController"

            prefWidth="1100.0" prefHeight="700.0"

            style="-fx-background-color: #f9f9f9;"

            nodeOrientation="RIGHT_TO_LEFT">



    <top>

        <HBox spacing="15.0" alignment="CENTER_RIGHT" style="-fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-background-color: #ffffff;" prefHeight="65.0">

            <padding>

                <Insets top="10.0" bottom="10.0" left="20.0" right="20.0"/>

            </padding>

            <children>

                <HBox alignment="CENTER" spacing="8">

                    <FontIcon iconLiteral="fas-user-circle" iconSize="22" iconColor="#a62626"/>

                    <VBox alignment="CENTER_RIGHT" spacing="2.0">

                        <children>

                            <Label text="دیوار من" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #a62626;"/>

                            <Label text="حساب کاربری کاربر" style="-fx-font-size: 11px; -fx-text-fill: #999999;"/>

                        </children>

                    </VBox>

                </HBox>



                <Region HBox.hgrow="ALWAYS" />



                <Button onAction="#goToChat"

                        style="-fx-background-color: white; -fx-text-fill: #222222; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-padding: 6px 14px; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;">

                    <graphic>

                        <HBox alignment="CENTER" spacing="6">

                            <FontIcon iconLiteral="fas-comment-dots" iconSize="14" iconColor="#666666"/>

                            <Label text="چت" style="-fx-text-fill: #666666; -fx-font-size: 13px; -fx-font-weight: bold;"/>

                        </HBox>

                    </graphic>

                </Button>

                <Button fx:id="backBtn" onAction="#goBack"

                        style="-fx-background-color: white; -fx-text-fill: #222222; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-padding: 6px 14px; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;">

                    <graphic>

                        <HBox alignment="CENTER" spacing="6">

                            <FontIcon iconLiteral="fas-arrow-right" iconSize="14" iconColor="#666666"/>

                            <Label text="بازگشت" style="-fx-text-fill: #666666; -fx-font-size: 13px; -fx-font-weight: bold;"/>

                        </HBox>

                    </graphic>

                </Button>

            </children>

        </HBox>

    </top>



    <left>

        <ScrollPane fitToWidth="true" style="-fx-background-color: #ffffff; -fx-border-color: 0 1 0 0; -fx-border-color: #e0e0e0;" prefWidth="240.0" nodeOrientation="RIGHT_TO_LEFT">

            <content>

                <HBox styleClass="profile-sidebar" style="-fx-background-color: #ffffff;">

                    <children>

                        <VBox spacing="15.0"  HBox.hgrow="ALWAYS" style="-fx-padding: 20px 15px 20px 10px;" nodeOrientation="RIGHT_TO_LEFT">

                            <children>

                                <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 4 0 4 0;" nodeOrientation="LEFT_TO_RIGHT">

                                    <Hyperlink fx:id="favoriteLink" text="علاقه‌مندی ها" onAction="#showFavorites"

                                               styleClass="menu-link-normal" alignment="CENTER_RIGHT" textAlignment="RIGHT" maxWidth="Infinity"/>

                                    <FontIcon iconLiteral="fas-heart" iconSize="16" iconColor="#555555"/>

                                </HBox>



                                <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 4 0 4 0;" nodeOrientation="LEFT_TO_RIGHT">

                                    <Hyperlink fx:id="advertisementLink" text="آگهی‌های من" onAction="#showMyAdvertisements"

                                               styleClass="menu-link-normal" alignment="CENTER_RIGHT" textAlignment="RIGHT" maxWidth="Infinity"/>

                                    <FontIcon iconLiteral="fas-list-ul" iconSize="16" iconColor="#555555"/>

                                </HBox>



                                <Region VBox.vgrow="ALWAYS" />



                                <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 4 0 4 0;" nodeOrientation="LEFT_TO_RIGHT">

                                    <Button text="خروج از حساب" onAction="#logout"

                                            style="-fx-background-color: transparent; -fx-text-fill: #a62626; -fx-font-size: 14px; -fx-padding: 5px 0; -fx-cursor: hand; -fx-font-weight: bold;"/>

                                    <FontIcon iconLiteral="fas-sign-out-alt" iconSize="16" iconColor="#a62626"/>

                                </HBox>

                            </children>

                        </VBox>



                        <VBox fx:id="indicatorContainer" prefWidth="4.0" style="-fx-padding: 20px 0 20px 0;" alignment="CENTER_LEFT">

                            <children>

                                <Region fx:id="activeIndicator" prefHeight="26.0" prefWidth="4.0" style="-fx-background-color: #a62626;" visible="false"/>

                            </children>

                        </VBox>

                    </children>

                </HBox>

            </content>

        </ScrollPane>

    </left>



    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-background-insets: 0; -fx-padding: 0;" nodeOrientation="LEFT_TO_RIGHT">
            <content>
                <StackPane style="-fx-background-color: transparent; -fx-padding: 40px;" alignment="CENTER" nodeOrientation="RIGHT_TO_LEFT">
                    <children>
                        <VBox fx:id="menu" spacing="15.0" style="-fx-background-color: transparent;" alignment="TOP_RIGHT"/>
                        <Label fx:id="emptyLabel" text="لطفاً یکی از گزینه‌های منو را انتخاب کنید."
                               style="-fx-font-size: 15px; -fx-text-fill: #888888; -fx-font-weight: bold;"
                               StackPane.alignment="CENTER"/>
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </center>

</BorderPane>



