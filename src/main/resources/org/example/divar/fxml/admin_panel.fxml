<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.divar.controller.AdminController"
            prefWidth="1100.0" prefHeight="700.0"
            style="-fx-background-color: #f9f9f9;"
            nodeOrientation="RIGHT_TO_LEFT">

    <top>
        <VBox spacing="6.0" style="-fx-background-color: #ffffff; -fx-border-color: #e3e3e3; -fx-border-width: 0 0 1px 0; -fx-padding: 20px 30px;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Label text="پنل مدیریت - بررسی آگهی‌ها" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="بروزرسانی" onAction="#refresh"
                                style="-fx-background-color: transparent; -fx-border-color: #a62626; -fx-text-fill: #a62626; -fx-font-size: 13px; -fx-padding: 6px 14px; -fx-background-radius: 6px; -fx-border-radius: 6px; -fx-cursor: hand;"/>
                        <Button text="بازگشت" onAction="#goBack"
                                style="-fx-background-color: transparent; -fx-text-fill: #444444; -fx-font-size: 13px; -fx-padding: 6px 14px; -fx-cursor: hand;"/>
                    </children>
                </HBox>
                <Label fx:id="messageLabel" wrapText="true" maxWidth="Infinity" visible="false" style="-fx-font-size: 13px;"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-background-insets: 0;">
            <content>
                <StackPane style="-fx-background-color: #f9f9f9; -fx-padding: 30px;" alignment="TOP_CENTER">
                    <children>
                        <VBox fx:id="pendingAdsBox" spacing="15.0" maxWidth="800.0"/>
                        <Label fx:id="emptyLabel" visible="false"
                               style="-fx-font-size: 15px; -fx-text-fill: #888888; -fx-font-weight: bold;"
                               StackPane.alignment="CENTER"/>
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </center>

</BorderPane>


