<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.divar.controller.AdminController"
            prefWidth="1250.0" prefHeight="760.0"
            style="-fx-background-color: #f9f9f9;">

    <top>
        <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="admin-topbar">
            <children>
                <Label text="پنل مدیریت" style="-fx-text-fill: #999999; -fx-font-size: 13px; -fx-padding: 4px 0 0 0;"/>
                <Label text="دیوار" styleClass="admin-logo"/>
            </children>
        </HBox>
    </top>

    <right>
        <VBox styleClass="admin-sidebar" prefWidth="230.0" spacing="4.0">
            <children>
                <Button fx:id="dashboardBtn"
                        text="داشبورد"
                        prefWidth="230.0"
                        maxWidth="Infinity"
                        alignment="CENTER_RIGHT"
                        contentDisplay="RIGHT"
                        nodeOrientation="LEFT_TO_RIGHT"
                        style="-fx-alignment: CENTER_RIGHT; -fx-padding: 12px 24px;"
                        onAction="#showDashboard">
                    <graphic>
                        <FontIcon iconLiteral="fas-tachometer-alt" iconSize="15" iconColor="#666666"/>
                    </graphic>
                </Button>

                <Button fx:id="adsBtn"
                        text="آگهی‌ها"
                        prefWidth="230.0"
                        maxWidth="Infinity"
                        alignment="CENTER_RIGHT"
                        contentDisplay="RIGHT"
                        nodeOrientation="LEFT_TO_RIGHT"
                        style="-fx-alignment: CENTER_RIGHT; -fx-padding: 12px 24px;"
                        onAction="#showAds">
                    <graphic>
                        <FontIcon iconLiteral="fas-bullhorn" iconSize="15" iconColor="#666666"/>
                    </graphic>
                </Button>

                <Button fx:id="reportsBtn"
                        text="گزارش‌ها"
                        prefWidth="230.0"
                        maxWidth="Infinity"
                        alignment="CENTER_RIGHT"
                        contentDisplay="RIGHT"
                        nodeOrientation="LEFT_TO_RIGHT"
                        style="-fx-alignment: CENTER_RIGHT; -fx-padding: 12px 24px;"
                        onAction="#showReports">
                    <graphic>
                        <FontIcon iconLiteral="fas-flag" iconSize="15" iconColor="#666666"/>
                    </graphic>
                </Button>

                <Button fx:id="usersBtn"
                        text="کاربران"
                        prefWidth="230.0"
                        maxWidth="Infinity"
                        alignment="CENTER_RIGHT"
                        contentDisplay="RIGHT"
                        nodeOrientation="LEFT_TO_RIGHT"
                        style="-fx-alignment: CENTER_RIGHT; -fx-padding: 12px 24px;"
                        onAction="#showUsers">
                    <graphic>
                        <FontIcon iconLiteral="fas-users" iconSize="15" iconColor="#666666"/>
                    </graphic>
                </Button>

                <Button fx:id="statsDashboardBtn"
                        text="داشبورد آماری"
                        prefWidth="230.0"
                        maxWidth="Infinity"
                        alignment="CENTER_RIGHT"
                        contentDisplay="RIGHT"
                        nodeOrientation="LEFT_TO_RIGHT"
                        style="-fx-alignment: CENTER_RIGHT; -fx-padding: 12px 24px;"
                        onAction="#showStatsDashboard">
                    <graphic>
                        <FontIcon iconLiteral="fas-chart-bar" iconSize="15" iconColor="#666666"/>
                    </graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS"/>

                <Separator/>

                <Button text="خروج"
                        prefWidth="230.0"
                        maxWidth="Infinity"
                        alignment="CENTER_RIGHT"
                        contentDisplay="RIGHT"
                        nodeOrientation="LEFT_TO_RIGHT"
                        style="-fx-background-color: transparent; -fx-text-fill: #a62626; -fx-font-size: 14px; -fx-padding: 12px 24px; -fx-alignment: CENTER_RIGHT; -fx-cursor: hand;"
                        onAction="#logout">
                    <graphic>
                        <FontIcon iconLiteral="fas-sign-out-alt" iconSize="15" iconColor="#a62626"/>
                    </graphic>
                </Button>
            </children>
        </VBox>
    </right>

    <center>
        <StackPane fx:id="contentArea" styleClass="admin-content"/>
    </center>

</BorderPane>


