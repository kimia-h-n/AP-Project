<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<fx:root type="javafx.scene.layout.VBox" spacing="10.0" prefWidth="220.0"
         styleClass="admin-card" style="-fx-padding: 12px;"
         nodeOrientation="RIGHT_TO_LEFT"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <StackPane style="-fx-background-color: #f2f2f2; -fx-background-radius: 6px;" prefHeight="140.0">
            <children>
                <ImageView fx:id="adImage" fitWidth="196.0" fitHeight="140.0" preserveRatio="true"/>
            </children>
        </StackPane>

        <Label fx:id="titleLabel" styleClass="admin-card-title" wrapText="true" maxWidth="Infinity"/>
        <Label fx:id="priceLabel" styleClass="admin-card-price" maxWidth="Infinity"/>
        <Label fx:id="cityLabel" styleClass="admin-card-location" maxWidth="Infinity"/>

        <Label fx:id="errorLabel" visible="false" managed="false" wrapText="true" maxWidth="Infinity"
               style="-fx-font-size: 11px; -fx-text-fill: #a62626; -fx-font-weight: bold;"/>

        <Region VBox.vgrow="ALWAYS" />

        <Button fx:id="removeBtn" text="حذف نشان" maxWidth="Infinity" prefHeight="32.0"
                style="-fx-background-color: transparent; -fx-border-color: #a62626; -fx-text-fill: #a62626; -fx-border-radius: 4px; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 12px;"/>
    </children>
</fx:root>