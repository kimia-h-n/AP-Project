<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.divar.component.ReasonDialog"
      spacing="12.0" nodeOrientation="RIGHT_TO_LEFT" prefWidth="400.0" prefHeight="320.0"
      style="-fx-background-color: white; -fx-padding: 20px; -fx-background-radius: 12px; -fx-border-radius: 12px; -fx-border-color: #eeeeee; -fx-border-width: 1px;">

    <children>
        <HBox alignment="TOP_RIGHT">
            <children>
                <Button fx:id="closeBtn" text="×" style="-fx-background-color: transparent; -fx-text-fill: #999999; -fx-font-size: 20px; -fx-cursor: hand; -fx-padding: 0;"/>
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT">
            <children>
                <Label fx:id="dialogTitle" text="دلیل حذف آگهی" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #222222;"/>
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT">
            <children>
                <Label fx:id="dialogSubtitle" text="لطفاً دلیل حذف این آگهی را وارد کنید." wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            </children>
        </HBox>

        <TextArea fx:id="reasonArea" promptText="دلیل حذف آگهی را بنویسید..." prefRowCount="4" wrapText="true" nodeOrientation="RIGHT_TO_LEFT"
                  style="-fx-background-color: transparent; -fx-border-color: #e0e0e0; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-font-size: 13px; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;"/>

        <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-padding: 10px 0 0 0;">
            <children>
                <Button fx:id="submitBtn" text="ثبت" style="-fx-background-color: #a62626; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8px 32px; -fx-background-radius: 6px; -fx-cursor: hand; -fx-font-weight: bold;"/>
                <Button fx:id="cancelBtn" text="انصراف" style="-fx-background-color: white; -fx-text-fill: #222222; -fx-border-color: #e0e0e0; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-font-size: 14px; -fx-padding: 8px 32px; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </children>
        </HBox>
    </children>
</VBox>
