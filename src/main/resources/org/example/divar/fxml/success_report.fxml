<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0"
      styleClass="success-dialog-root"
      prefWidth="320.0" nodeOrientation="RIGHT_TO_LEFT"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.divar.controller.ReportDialogController">

    <children>
        <Label text="گزارش شما با موفقیت ثبت شد."
               styleClass="success-dialog-label" />

        <Button text="تأیید" onAction="#closeSuccessWindow"
                styleClass="success-dialog-btn" />
    </children>
</VBox>
