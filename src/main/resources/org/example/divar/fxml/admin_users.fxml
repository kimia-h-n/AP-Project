<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.divar.controller.AdminUsersController"
      spacing="18.0" nodeOrientation="RIGHT_TO_LEFT">
    <children>

        <VBox spacing="4.0">
            <children>
                <Label text="مدیریت کاربران" styleClass="admin-page-title"/>
                <Label text="لیست تمامی کاربران ثبت‌شده در سیستم" styleClass="admin-page-subtitle"/>
            </children>
        </VBox>

        <Label fx:id="messageLabel" wrapText="true" maxWidth="Infinity" visible="false" managed="false"/>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;" VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="cardsContainer" hgap="15.0" vgap="15.0" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets bottom="20.0" left="5.0" right="5.0" top="5.0"/>
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>

    </children>
</VBox>