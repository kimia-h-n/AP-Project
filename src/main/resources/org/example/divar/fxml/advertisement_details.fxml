<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.divar.controller.AdvertisementDetailsController"
            prefWidth="1150.0" prefHeight="760.0" style="-fx-background-color: #f9f9f9;" nodeOrientation="RIGHT_TO_LEFT">

    <top>
        <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-background-color: #ffffff;" prefHeight="65.0">
            <padding>
                <Insets top="10.0" bottom="10.0" left="20.0" right="20.0"/>
            </padding>
            <children>
                <VBox alignment="CENTER_RIGHT" spacing="2.0">
                    <children>
                        <Label text="جزئیات آگهی" style="-fx-text-fill: #a62626; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <Label text="نمایش اطلاعات آگهی" style="-fx-text-fill: #999999; -fx-font-size: 11px;"/>
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button text="چت" onAction="#goToChat" style="-fx-background-color: white; -fx-text-fill: #222222; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-padding: 6px 14px; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                <Button text="پروفایل من" onAction="#goToProfile" style="-fx-background-color: white; -fx-text-fill: #222222; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-padding: 6px 14px; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                <Button text="بازگشت" onAction="#goBack" style="-fx-background-color: white; -fx-text-fill: #222222; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-padding: 6px 14px; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0;">
            <content>
                <VBox spacing="30.0">
                    <padding>
                        <Insets top="30.0" bottom="40.0" left="50.0" right="50.0"/>
                    </padding>
                    <children>

                        <HBox spacing="30.0" alignment="TOP_CENTER">
                            <children>

                                <VBox spacing="0.0" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color: #ffffff; -fx-padding: 25px; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-width: 1px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 2);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="عنوان" prefWidth="150.0" style="-fx-text-fill: #888888; -fx-font-size: 14px;"/>
                                            <Label fx:id="titleLabel" wrapText="true" HBox.hgrow="ALWAYS" style="-fx-text-fill: #222222; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="TOP_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="توضیحات" prefWidth="150.0" style="-fx-text-fill: #888888; -fx-font-size: 14px;"/>
                                            <Label fx:id="descriptionLabel" wrapText="true" HBox.hgrow="ALWAYS" style="-fx-text-fill: #222222; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="دسته‌بندی" prefWidth="150.0" style="-fx-text-fill: #888888; -fx-font-size: 14px;"/>
                                            <Label fx:id="categoryLabel" style="-fx-text-fill: #222222; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="وضعیت کالا" prefWidth="150.0" style="-fx-text-fill: #888888; -fx-font-size: 14px;"/>
                                            <Label fx:id="conditionLabel" style="-fx-text-fill: #2e7d32; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #e8f5e9; -fx-padding: 4px 10px; -fx-background-radius: 4px;"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="قیمت" prefWidth="150.0" style="-fx-text-fill: #888888; -fx-font-size: 14px;"/>
                                            <Label fx:id="priceLabel" style="-fx-text-fill: #a62626; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="شهر" prefWidth="150.0" style="-fx-text-fill: #888888; -fx-font-size: 14px;"/>
                                            <Label fx:id="cityLabel" style="-fx-text-fill: #222222; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="آدرس" prefWidth="150.0" style="-fx-text-fill: #888888; -fx-font-size: 14px;"/>
                                            <Label fx:id="addressLabel" style="-fx-text-fill: #222222; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="تاریخ ثبت" prefWidth="150.0" style="-fx-text-fill: #888888; -fx-font-size: 14px;"/>
                                            <Label fx:id="createdAtLabel" style="-fx-text-fill: #222222; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="تاریخ بروزرسانی" prefWidth="150.0" style="-fx-text-fill: #888888; -fx-font-size: 14px;"/>
                                            <Label fx:id="updatedAtLabel" style="-fx-text-fill: #222222; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <!-- بخش اطلاعات فروشنده همراه با امتیاز -->
                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="فروشنده" prefWidth="150.0" style="-fx-text-fill: #888888; -fx-font-size: 14px;"/>
                                            <VBox spacing="8.0"> <!-- افزایش فاصله بین اسم و امتیاز به 8px -->
                                                <children>
                                                    <Label fx:id="sellerLabel" style="-fx-text-fill: #222222; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                                    <HBox alignment="CENTER_LEFT" spacing="6.0">
                                                        <children>
                                                            <Label text="★" style="-fx-text-fill: #ffc107; -fx-font-size: 14px;" />
                                                            <!-- اضافه شدن بولد و رنگ تیره‌تر -->
                                                            <Label fx:id="lblSellerRating" text="در حال دریافت..." style="-fx-text-fill: #333333; -fx-font-size: 13px; -fx-font-weight: bold;" />
                                                        </children>
                                                    </HBox>
                                                </children>
                                            </VBox>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="15.0" alignment="TOP_CENTER" prefWidth="460.0">
                                    <children>
                                        <StackPane prefWidth="460.0" prefHeight="340.0"
                                                   style="-fx-background-color: #f5f5f5; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px;">
                                            <children>
                                                <ImageView fx:id="mainImage" fitWidth="450.0" fitHeight="330.0" preserveRatio="true"/>
                                                <Button text="›" styleClass="gallery-arrow" onAction="#showPrevious" StackPane.alignment="CENTER_LEFT">
                                                    <StackPane.margin>
                                                        <Insets top="0" right="0" bottom="0" left="10"/>
                                                    </StackPane.margin>
                                                </Button>
                                                <Button text="‹" styleClass="gallery-arrow" onAction="#showNext" StackPane.alignment="CENTER_RIGHT">
                                                    <StackPane.margin>
                                                        <Insets top="0" right="10" bottom="0" left="0"/>
                                                    </StackPane.margin>
                                                </Button>
                                                <Label fx:id="counterLabel" styleClass="gallery-counter" StackPane.alignment="TOP_LEFT">
                                                    <StackPane.margin>
                                                        <Insets top="12" left="12"/>
                                                    </StackPane.margin>
                                                </Label>
                                            </children>
                                        </StackPane>
                                        <HBox fx:id="thumbnailBox" spacing="10.0" alignment="CENTER"/>
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <VBox spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 25px; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-width: 1px;">
                            <children>
                                <Label text="عملیات آگهی" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #222222;"/>
                                <Label fx:id="messageLabel" wrapText="true" maxWidth="Infinity" style="-fx-font-size: 13px; " visible="false"/>

                                <HBox spacing="15.0" alignment="CENTER">
                                    <children>
                                        <Button fx:id="chatBtn" text="چت با فروشنده" onAction="#chatWithSeller" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                                style="-fx-background-color: white; -fx-text-fill: #222222; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-font-size: 14px; -fx-padding: 12px 0; -fx-cursor: hand; -fx-font-weight: bold;"/>

                                        <Button fx:id="favoriteBtn" text="افزودن به علاقه‌مندی" onAction="#manageFavoriteAdvertisement" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                                style="-fx-background-color: white; -fx-text-fill: #222222; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-font-size: 14px; -fx-padding: 12px 0; -fx-cursor: hand; -fx-font-weight: bold;"/>

                                        <Button fx:id="rateSellerBtn" text="امتیاز به فروشنده" onAction="#rateSeller" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                                style="-fx-background-color: white; -fx-text-fill: #222222; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-font-size: 14px; -fx-padding: 12px 0; -fx-cursor: hand; -fx-font-weight: bold;"/>

                                        <Button fx:id="editBtn" text="ویرایش آگهی" onAction="#editAdvertisement" visible="false" managed="false" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                                style="-fx-background-color: white; -fx-text-fill: #1565c0; -fx-border-color: #1565c0; -fx-border-radius: 4px; -fx-font-size: 14px; -fx-padding: 12px 0; -fx-cursor: hand; -fx-font-weight: bold;"/>

                                        <Button fx:id="deleteBtn" text="حذف آگهی" onAction="#deleteAdvertisement" visible="false" managed="false" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                                style="-fx-background-color: white; -fx-text-fill: #a62626; -fx-border-color: #a62626; -fx-border-radius: 4px; -fx-font-size: 14px; -fx-padding: 12px 0; -fx-cursor: hand; -fx-font-weight: bold;"/>

                                        <Button fx:id="reportButton" text="گزارش این آگهی" onAction="#reportAdvertisement" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                                style="-fx-background-color: white; -fx-text-fill: #a62626; -fx-border-color: #a62626; -fx-border-radius: 4px; -fx-font-size: 14px; -fx-padding: 12px 0; -fx-cursor: hand; -fx-font-weight: bold;"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
