<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<fx:root type="javafx.scene.layout.VBox" spacing="8.0"
         style="-fx-background-color: white; -fx-border-color: #e3e3e3; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 15px;"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <Label fx:id="titleLabel" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
        <Label fx:id="infoLabel" style="-fx-font-size: 12px; -fx-text-fill: #888888;"/>
        <Label fx:id="descriptionLabel" wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #555555;"/>
        <Label fx:id="messageLabel" wrapText="true" maxWidth="Infinity" visible="false" style="-fx-font-size: 12px; -fx-text-fill: #a62626; -fx-font-weight: bold;"/>
        <HBox spacing="10.0">
            <children>
                <Button fx:id="approveBtn" text="تایید آگهی"
                        style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8px 16px; -fx-background-radius: 6px; -fx-cursor: hand;"/>
                <Button fx:id="rejectBtn" text="رد آگهی"
                        style="-fx-background-color: #a62626; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8px 16px; -fx-background-radius: 6px; -fx-cursor: hand;"/>
            </children>
        </HBox>
    </children>
</fx:root>


