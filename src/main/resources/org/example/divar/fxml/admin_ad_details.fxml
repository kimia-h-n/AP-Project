<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.divar.controller.AdminAdDetailsController"
            prefWidth="1150.0" prefHeight="760.0" style="-fx-background-color: #f9f9f9;"
            nodeOrientation="RIGHT_TO_LEFT">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="admin-topbar">
            <children>
                <VBox alignment="CENTER_RIGHT">
                    <Label text="جزئیات آگهی" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #be1c1c;"/>
                    <Label text="نمایش اطلاعات آگهی" styleClass="admin-page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="چت با کاربر" styleClass="admin-topbar-btn" onAction="#openChat"/>
                <Button text="بازگشت" styleClass="admin-topbar-btn" onAction="#goBack"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0;">
            <content>
                <VBox spacing="30.0">
                    <padding>
                        <Insets top="30.0" bottom="40.0" left="50.0" right="50.0"/>
                    </padding>
                    <children>

                        <HBox spacing="30.0" alignment="TOP_CENTER">
                            <children>

                                <VBox spacing="0.0" HBox.hgrow="ALWAYS" styleClass="details-info-box">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="عنوان" styleClass="info-row-label" prefWidth="120.0"/>
                                            <Label fx:id="titleLabel" styleClass="info-row-value" wrapText="true" HBox.hgrow="ALWAYS"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="TOP_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="توضیحات" styleClass="info-row-label" prefWidth="120.0"/>
                                            <Label fx:id="descriptionLabel" styleClass="info-row-value" wrapText="true" HBox.hgrow="ALWAYS"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="دسته‌بندی" styleClass="info-row-label" prefWidth="120.0"/>
                                            <Label fx:id="categoryLabel" styleClass="info-row-value"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="وضعیت کالا" styleClass="info-row-label" prefWidth="120.0"/>
                                            <Label fx:id="conditionLabel" styleClass="status-pill-green"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="قیمت" styleClass="info-row-label" prefWidth="120.0"/>
                                            <Label fx:id="priceLabel" style="-fx-text-fill: #a62626; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="شهر" styleClass="info-row-label" prefWidth="120.0"/>
                                            <Label fx:id="cityLabel" styleClass="info-row-value"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="تاریخ ثبت" styleClass="info-row-label" prefWidth="120.0"/>
                                            <Label fx:id="createdAtLabel" styleClass="info-row-value"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="تاریخ بروزرسانی" styleClass="info-row-label" prefWidth="120.0"/>
                                            <Label fx:id="updatedAtLabel" styleClass="info-row-value"/>
                                        </HBox>
                                        <Separator style="-fx-opacity: 0.5;"/>

                                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 12px 0;">
                                            <Label text="کاربر" styleClass="info-row-label" prefWidth="120.0"/>
                                            <Label fx:id="sellerLabel" styleClass="info-row-value"/>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="15.0" alignment="TOP_CENTER" prefWidth="460.0">
                                    <children>
                                        <StackPane prefWidth="460.0" prefHeight="340.0"
                                                   style="-fx-background-color: #f5f5f5; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px;">
                                            <children>
                                                <ImageView fx:id="mainImage" fitWidth="450.0" fitHeight="330.0" preserveRatio="true"/>
                                                <Button text="›" styleClass="gallery-arrow" onAction="#showPrevious" StackPane.alignment="CENTER_LEFT">
                                                    <StackPane.margin>
                                                        <Insets top="0" right="0" bottom="0" left="10"/>
                                                    </StackPane.margin>
                                                </Button>
                                                <Button text="‹" styleClass="gallery-arrow" onAction="#showNext" StackPane.alignment="CENTER_RIGHT">
                                                    <StackPane.margin>
                                                        <Insets top="0" right="10" bottom="0" left="0"/>
                                                    </StackPane.margin>
                                                </Button>
                                                <Label fx:id="counterLabel" styleClass="gallery-counter" StackPane.alignment="TOP_LEFT">
                                                    <StackPane.margin>
                                                        <Insets top="12" left="12"/>
                                                    </StackPane.margin>
                                                </Label>
                                            </children>
                                        </StackPane>
                                        <HBox fx:id="thumbnailBox" spacing="10.0" alignment="CENTER"/>
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <VBox spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 25px; -fx-background-radius: 8px; -fx-border-color: #f0f0f0; -fx-border-width: 1px;">
                            <children>
                                <Label text="عملیات آگهی" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #222222;"/>
                                <Label fx:id="messageLabel" wrapText="true" maxWidth="Infinity" visible="false" managed="false"/>
                                <Button text="حذف آگهی" onAction="#deleteAdvertisement" maxWidth="Infinity" styleClass="btn-delete-ad"/>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>