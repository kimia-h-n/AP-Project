<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/fxml/1" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.divar.controller.LoginController"
           prefWidth="900" prefHeight="600" style="-fx-background-color: #f0f0f0;">

    <VBox alignment="CENTER" spacing="20" maxWidth="400" maxHeight="450"
          style="-fx-background-color: #ffffff; -fx-background-radius: 8px; -fx-padding: 40px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 12, 0, 0, 0);">

        <Label text="دیوار" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #a62626;"/>

        <Label text="ورود به حساب کاربری" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>

        <TextField fx:id="usernameField" prefHeight="40" promptText="نام کاربری"
                   nodeOrientation="RIGHT_TO_LEFT"
                   style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 4px;"/>

        <PasswordField fx:id="passwordField" prefHeight="40" promptText="رمز عبور"
                       nodeOrientation="RIGHT_TO_LEFT"
                       style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 4px;"/>

        <Button fx:id="loginBtn" onAction="#login" prefHeight="40" maxWidth="1.7976931348623157E308" text="ورود"
                style="-fx-background-color: #a62626; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 4px; -fx-cursor: hand;"/>

        <Label fx:id="messageLabel"
               wrapText="true"
               maxWidth="Infinity"
               visible="false"
               textAlignment="RIGHT"
               style="-fx-text-fill: #a62626; -fx-font-size: 12px; -fx-alignment: CENTER;"/>

        <Label onMouseClicked="#goToRegister" text="حساب ندارید؟ ثبت نام"
               style="-fx-text-fill: #a62626; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;"/>

    </VBox>
</StackPane>




